From: <author>
Subject: [PATCH] CUDA: support F16 weights in conv_transpose_1d

`ggml_cuda_op_conv_transpose_1d` previously hard-asserted
`src0->type == GGML_TYPE_F32`, and the CUDA backend's `supports_op`
returned `false` for any non-F32 kernel. CPU + Metal both accept F16
kernels here, so models that ship upsampler weights as F16 (audio
codec / vocoder decoders — SNAC, vibevoice generator, kokoro, etc.)
work on those backends and abort on CUDA.

Template the kernel + dispatch on src0 type (float / half), use
`ggml_cuda_cast<float>` from convert.cuh for the per-element load,
and relax the runtime assert + supports_op predicate from "F32 only"
to "F32 or F16". `src1` (the input) stays F32; `dst` stays F32.

For the F32 instantiation the `if constexpr (std::is_same_v<dst_t,
src_t>) return x;` branch in `ggml_cuda_cast` folds away, so the
generated PTX for the float specialization is the same as the
pre-patch kernel.

diff --git a/ggml/src/ggml-cuda/conv-transpose-1d.cu b/ggml/src/ggml-cuda/conv-transpose-1d.cu
--- a/ggml/src/ggml-cuda/conv-transpose-1d.cu
+++ b/ggml/src/ggml-cuda/conv-transpose-1d.cu
@@ -1,11 +1,13 @@
 #include "conv-transpose-1d.cuh"
+#include "convert.cuh"

-static  __global__ void conv_transpose_1d_kernel(
+template <typename src0_t>
+static __global__ void conv_transpose_1d_kernel(
         const int s0, const int p0, const int d0, const int output_size,
         const int src0_ne0, const int src0_ne1, const int src0_ne2, const int src0_ne3,
         const int src1_ne0, const int src1_ne1, const int src1_ne2, const int src1_ne3,
         const int dst_ne0, const int dst_ne1, const int dst_ne2, const int dst_ne3,
-        const float * src0, const float * src1,  float * dst) {
+        const src0_t * src0, const float * src1,  float * dst) {
     int global_index = threadIdx.x + blockIdx.x * blockDim.x;
     if (global_index >= output_size) {
         return;
@@ -27,7 +29,7 @@ static  __global__ void conv_transpose_1d_kernel(
             }
             int weight_idx = idx - i*s0;

-            float kernel_weight = src0[kernel_offset + weight_idx];
+            float kernel_weight = ggml_cuda_cast<float>(src0[kernel_offset + weight_idx]);
             float input_value =  src1[input_offset+i];

             accumulator += kernel_weight * input_value;
@@ -37,12 +39,13 @@ static  __global__ void conv_transpose_1d_kernel(
     GGML_UNUSED_VARS(p0, d0, src0_ne3, src1_ne3, dst_ne3, src1_ne1, dst_ne1, src1_ne2, dst_ne2);
 }

-static void conv_transpose_1d_f32_f32_cuda(
+template <typename src0_t>
+static void conv_transpose_1d_cuda(
         const int s0, const int p0, const int d0, const int output_size,
         const int src0_ne0, const int src0_ne1, const int src0_ne2, const int src0_ne3,
         const int src1_ne0, const int src1_ne1, const int src1_ne2, const int src1_ne3,
         const int dst_ne0, const int dst_ne1, const int dst_ne2, const int dst_ne3,
-        const float * src0, const float * src1,  float * dst,
+        const src0_t * src0, const float * src1,  float * dst,
         cudaStream_t stream) {

     const int num_blocks = (output_size + CUDA_CONV_TRANPOSE_1D_BLOCK_SIZE - 1) / CUDA_CONV_TRANPOSE_1D_BLOCK_SIZE;
@@ -56,15 +59,14 @@ static void conv_transpose_1d_f32_f32_cuda(

 void ggml_cuda_op_conv_transpose_1d(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
     const ggml_tensor * src0 = dst->src[0];
-    const float * src0_d = (const float *)src0->data;
-
     const ggml_tensor * src1 = dst->src[1];
     const float * src1_d = (const float *)src1->data;

     float * dst_d = (float *)dst->data;
     cudaStream_t stream = ctx.stream();

-    GGML_ASSERT(src0->type == GGML_TYPE_F32);
+    GGML_ASSERT(src0->type == GGML_TYPE_F32 || src0->type == GGML_TYPE_F16);
+    GGML_ASSERT(src1->type == GGML_TYPE_F32);
     GGML_ASSERT( dst->type == GGML_TYPE_F32);

     GGML_ASSERT(ggml_is_contiguous(src0));
@@ -78,9 +80,17 @@ void ggml_cuda_op_conv_transpose_1d(ggml_backend_cuda_context & ctx, ggml_tensor

     const int64_t output_size = ggml_nelements(dst);

-    conv_transpose_1d_f32_f32_cuda(s0, p0, d0, output_size,
-        src0->ne[0], src0->ne[1], src0->ne[2], src0->ne[3],
-        src1->ne[0], src1->ne[1], src1->ne[2], src1->ne[3],
-        dst->ne[0], dst->ne[1], dst->ne[2], dst->ne[3],
-        src0_d, src1_d, dst_d, stream);
+    if (src0->type == GGML_TYPE_F32) {
+        conv_transpose_1d_cuda<float>(s0, p0, d0, output_size,
+            src0->ne[0], src0->ne[1], src0->ne[2], src0->ne[3],
+            src1->ne[0], src1->ne[1], src1->ne[2], src1->ne[3],
+            dst->ne[0], dst->ne[1], dst->ne[2], dst->ne[3],
+            (const float *)src0->data, src1_d, dst_d, stream);
+    } else {
+        conv_transpose_1d_cuda<half>(s0, p0, d0, output_size,
+            src0->ne[0], src0->ne[1], src0->ne[2], src0->ne[3],
+            src1->ne[0], src1->ne[1], src1->ne[2], src1->ne[3],
+            dst->ne[0], dst->ne[1], dst->ne[2], dst->ne[3],
+            (const half *)src0->data, src1_d, dst_d, stream);
+    }
 }
diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -5097,7 +5097,7 @@ static bool ggml_backend_cuda_device_supports_op(ggml_backend_dev_t dev, const g
             {
                 ggml_type src0_type = op->src[0]->type;
                 ggml_type src1_type = op->src[1]->type;
-                if (src0_type == GGML_TYPE_F32 && src1_type == GGML_TYPE_F32) {
+                if ((src0_type == GGML_TYPE_F32 || src0_type == GGML_TYPE_F16) && src1_type == GGML_TYPE_F32) {
                     return true;
                 }
                 return false;
