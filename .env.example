STELNET_IMAGE=stelnet-local:main
STELNET_IMAGE_CUDA=stelnet-local:main-cuda
STELNET_PORT=8080
STELNET_MODEL=/models/model.gguf
STELNET_BACKEND=
STELNET_LANGUAGE=auto
STELNET_AUTO_DOWNLOAD=0
STELNET_CACHE_DIR=/cache
STELNET_API_KEYS=
# Optional startup flags, e.g. --frequency-penalty 0.4 for a server-wide default.
# Per-request /v1/audio/transcriptions fields max_tokens, max_new_tokens, and
# frequency_penalty override this for each request.
STELNET_EXTRA_ARGS=
STELNET_UID=1000
STELNET_GID=1000
