set(STELNET_VERSION      @STELNET_INSTALL_VERSION@)
set(STELNET_BUILD_COMMIT @STELNET_BUILD_COMMIT@)
set(STELNET_BUILD_NUMBER @STELNET_BUILD_NUMBER@)
set(STELNET_SHARED_LIB   @BUILD_SHARED_LIBS@)

@PACKAGE_INIT@

set_and_check(STELNET_INCLUDE_DIR "@PACKAGE_STELNET_INCLUDE_INSTALL_DIR@")
set_and_check(STELNET_LIB_DIR     "@PACKAGE_STELNET_LIB_INSTALL_DIR@")
set_and_check(STELNET_BIN_DIR     "@PACKAGE_STELNET_BIN_INSTALL_DIR@")

find_package(ggml REQUIRED HINTS ${LLAMA_LIB_DIR}/cmake)

find_library(stelnet_LIBRARY stelnet
    REQUIRED
    HINTS ${STELNET_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(stelnet UNKNOWN IMPORTED)
set_target_properties(stelnet
    PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${STELNET_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${stelnet_LIBRARY}"
        INTERFACE_COMPILE_FEATURES cxx_std_11
        POSITION_INDEPENDENT_CODE ON )

check_required_components(stelnet)
